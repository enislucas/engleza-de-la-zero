    {
      "id": "g1",
      "title": "Cele trei forme ale lui „to be”",
      "body": "În engleză, „a fi” are trei forme la prezent: I AM (eu sunt), he/she/it IS (el/ea este), you/we/they ARE (tu ești, noi/voi/ei sunt). Regulă simplă: el/ea/lucrul primesc IS, toți ceilalți AM sau ARE.",
      "examples": [
        {"en": "I am Maria.", "ro": "Eu sunt Maria."},
        {"en": "He is my son.", "ro": "El este fiul meu."},
        {"en": "We are a family.", "ro": "Noi suntem o familie."},
        {"en": "They are at home.", "ro": "Ei sunt acasă."}
      ]
    },
    {
      "id": "g2",
      "title": "Vârsta se spune cu „to be”, nu cu „have”",
      "body": "În engleză NU spui „am 50 de ani” cu verbul „a avea”. Se folosește „to be”: I AM 50. Aceasta e una dintre cele mai frecvente greșeli ale românilor.",
      "examples": [
        {"en": "I am 50.", "ro": "Am 50 de ani."},
        {"en": "He is 25.", "ro": "El are 25 de ani."}
      ]
    }
  ],
