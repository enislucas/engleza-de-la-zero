{"book":1,"vocab":[{"id":"w0001","en":"I","ro":"eu","pron":"ai","cat":"pronume"},{"id":"w0002","en":"you","ro":"tu / voi","pron":"iu","cat":"pronume"},{"id":"w0003","en":"he","ro":"el","pron":"hi","cat":"pronume"},{"id":"w0004","en":"she","ro":"ea","pron":"și","cat":"pronume"},{"id":"w0005","en":"it","ro":"acela (lucru)","pron":"it","cat":"pronume"},{"id":"w0006","en":"we","ro":"noi","pron":"ui","cat":"pronume"},{"id":"w0007","en":"they","ro":"ei / ele","pron":"dei","cat":"pronume"},{"id":"w0008","en":"this","ro":"acesta","pron":"dis","cat":"pronume"},{"id":"w0009","en":"that","ro":"acela","pron":"det","cat":"pronume"},{"id":"w0010","en":"am","ro":"sunt","pron":"em","cat":"verb"},{"id":"w0011","en":"is","ro":"este","pron":"iz","cat":"verb"},{"id":"w0012","en":"are","ro":"ești / sunt","pron":"ar","cat":"verb"},{"id":"w0013","en":"be","ro":"a fi","pron":"bi","cat":"verb"},{"id":"w0014","en":"family","ro":"familie","pron":"femili","cat":"substantiv"},{"id":"w0015","en":"mother","ro":"mamă","pron":"madher","cat":"substantiv"},{"id":"w0016","en":"father","ro":"tată","pron":"fadher","cat":"substantiv"},{"id":"w0017","en":"wife","ro":"soție","pron":"uaif","cat":"substantiv"},{"id":"w0018","en":"husband","ro":"soț","pron":"hazbănd","cat":"substantiv"},{"id":"w0019","en":"friend","ro":"prieten","pron":"frend","cat":"substantiv"},{"id":"w0020","en":"name","ro":"nume","pron":"neim","cat":"substantiv"},{"id":"w0021","en":"tired","ro":"obosit","pron":"taird","cat":"adjectiv"},{"id":"w0022","en":"happy","ro":"fericit","pron":"hepi","cat":"adjectiv"},{"id":"w0023","en":"hungry","ro":"flămând","pron":"hangri","cat":"adjectiv"},{"id":"w0024","en":"cold","ro":"rece / frig","pron":"could","cat":"adjectiv"},{"id":"w0025","en":"home","ro":"acasă","pron":"houm","cat":"substantiv"},{"id":"w0026","en":"work","ro":"muncă","pron":"uerc","cat":"substantiv"},{"id":"w0027","en":"working","ro":"lucrând","pron":"uerching","cat":"verb"},{"id":"w0028","en":"eating","ro":"mâncând","pron":"iiting","cat":"verb"},{"id":"w0029","en":"sleeping","ro":"dormind","pron":"sliiping","cat":"verb"},{"id":"w0030","en":"reading","ro":"citind","pron":"riiding","cat":"verb"},{"id":"w0031","en":"playing","ro":"jucând","pron":"pleing","cat":"verb"},{"id":"w0032","en":"watching","ro":"privind","pron":"uociing","cat":"verb"},{"id":"w0033","en":"running","ro":"alergând","pron":"raning","cat":"verb"},{"id":"w0034","en":"learning","ro":"învățând","pron":"lerning","cat":"verb"},{"id":"w0035","en":"writing","ro":"scriind","pron":"raiting","cat":"verb"},{"id":"w0036","en":"going","ro":"mergând (spre)","pron":"going","cat":"verb"},{"id":"w0037","en":"book","ro":"carte","pron":"buc","cat":"substantiv"},{"id":"w0038","en":"food","ro":"mâncare","pron":"fud","cat":"substantiv"},{"id":"w0039","en":"water","ro":"apă","pron":"uotăr","cat":"substantiv"},{"id":"w0040","en":"car","ro":"mașină","pron":"car","cat":"substantiv"},{"id":"w0041","en":"new","ro":"nou","pron":"niu","cat":"adjectiv"},{"id":"w0042","en":"old","ro":"vechi / bătrân","pron":"ould","cat":"adjectiv"},{"id":"w0043","en":"good","ro":"bun","pron":"gud","cat":"adjectiv"},{"id":"w0044","en":"nice","ro":"plăcut","pron":"nais","cat":"adjectiv"},{"id":"w0045","en":"what","ro":"ce","pron":"uat","cat":"pronume"},{"id":"w0046","en":"who","ro":"cine","pron":"hu","cat":"pronume"},{"id":"w0047","en":"where","ro":"unde","pron":"uer","cat":"adverb"},{"id":"w0048","en":"when","ro":"când","pron":"uen","cat":"adverb"},{"id":"w0049","en":"why","ro":"de ce","pron":"uai","cat":"adverb"},{"id":"w0050","en":"how","ro":"cum","pron":"hau","cat":"adverb"},{"id":"w0051","en":"yes","ro":"da","pron":"ies","cat":"expresie"},{"id":"w0052","en":"no","ro":"nu","pron":"nou","cat":"expresie"},{"id":"w0053","en":"maybe","ro":"poate","pron":"meibi","cat":"expresie"},{"id":"w0054","en":"shop","ro":"magazin","pron":"șop","cat":"substantiv"},{"id":"w0055","en":"station","ro":"gară","pron":"steișon","cat":"substantiv"},{"id":"w0056","en":"hotel","ro":"hotel","pron":"ho-tel","cat":"substantiv"},{"id":"w0057","en":"open","ro":"deschis","pron":"oupăn","cat":"adjectiv"},{"id":"w0058","en":"closed","ro":"închis","pron":"clouzd","cat":"adjectiv"},{"id":"w0059","en":"expensive","ro":"scump","pron":"ec-spensiv","cat":"adjectiv"},{"id":"w0060","en":"not","ro":"nu (negare)","pron":"not","cat":"adverb"},{"id":"w0061","en":"never","ro":"niciodată","pron":"nevăr","cat":"adverb"},{"id":"w0062","en":"today","ro":"azi","pron":"tudei","cat":"adverb"},{"id":"w0063","en":"tomorrow","ro":"mâine","pron":"tumoro","cat":"adverb"},{"id":"w0064","en":"yesterday","ro":"ieri","pron":"iestărdei","cat":"adverb"},{"id":"w0065","en":"now","ro":"acum","pron":"nau","cat":"adverb"},{"id":"w0066","en":"day","ro":"zi","pron":"dei","cat":"substantiv"},{"id":"w0067","en":"week","ro":"săptămână","pron":"uic","cat":"substantiv"},{"id":"w0068","en":"month","ro":"lună","pron":"mant","cat":"substantiv"},{"id":"w0069","en":"year","ro":"an","pron":"iir","cat":"substantiv"},{"id":"w0070","en":"morning","ro":"dimineață","pron":"morning","cat":"substantiv"},{"id":"w0071","en":"hello","ro":"salut","pron":"helou","cat":"expresie"},{"id":"w0072","en":"hi","ro":"salut","pron":"hai","cat":"expresie"},{"id":"w0073","en":"goodbye","ro":"la revedere","pron":"gud-bai","cat":"expresie"},{"id":"w0074","en":"bye","ro":"pa","pron":"bai","cat":"expresie"},{"id":"w0075","en":"please","ro":"te rog","pron":"pliz","cat":"expresie"},{"id":"w0076","en":"thanks","ro":"mersi","pron":"tencs","cat":"expresie"},{"id":"w0077","en":"sorry","ro":"îmi pare rău","pron":"sori","cat":"expresie"},{"id":"w0078","en":"welcome","ro":"bine ai venit","pron":"uel-căm","cat":"expresie"},{"id":"w0079","en":"can","ro":"pot / poți","pron":"chen","cat":"verb"},{"id":"w0080","en":"could","ro":"aș putea","pron":"cud","cat":"verb"},{"id":"w0081","en":"like","ro":"a-i plăcea","pron":"laic","cat":"verb"},{"id":"w0082","en":"want","ro":"a vrea","pron":"uont","cat":"verb"},{"id":"w0083","en":"need","ro":"a avea nevoie","pron":"nid","cat":"verb"},{"id":"w0084","en":"ticket","ro":"bilet","pron":"tichit","cat":"substantiv"},{"id":"w0085","en":"coffee","ro":"cafea","pron":"co-fi","cat":"substantiv"},{"id":"w0086","en":"doctor","ro":"doctor","pron":"doc-tor","cat":"substantiv"}],"sentences":[{"id":"s001","en":"I am 50 years old.","ro":"Am 50 de ani.","words":["w0001","w0010","w0042"]},{"id":"s002","en":"Is the cat playing?","ro":"Se joacă pisica?","words":["w0011","w0031"]},{"id":"s003","en":"Yes, I am.","ro":"Da, sunt.","words":["w0001","w0010","w0051"]},{"id":"s004","en":"Yes, I am tired.","ro":"Da, sunt obosit.","words":["w0001","w0010","w0021","w0051"]},{"id":"s005","en":"I am working at a supermarket.","ro":"Lucrez la un supermarket.","words":["w0001","w0010","w0027"]},{"id":"s006","en":"He is not working today.","ro":"El nu lucrează azi.","words":["w0003","w0011","w0027","w0060","w0062"]},{"id":"s007","en":"He doesn't work today.","ro":"El nu lucrează azi.","words":["w0003","w0026","w0062"]},{"id":"s008","en":"The cat is playing.","ro":"Pisica se joacă.","words":["w0011","w0031"]},{"id":"s009","en":"I am Romanian.","ro":"Eu sunt român.","words":["w0001","w0010"]},{"id":"s010","en":"I am from Bucharest.","ro":"Sunt din București.","words":["w0001","w0010"]},{"id":"s011","en":"She is my wife.","ro":"Ea e soția mea.","words":["w0004","w0011","w0017"]},{"id":"s012","en":"He is my son.","ro":"El e fiul meu.","words":["w0003","w0011"]},{"id":"s013","en":"We are a family.","ro":"Suntem o familie.","words":["w0006","w0012","w0014"]},{"id":"s014","en":"They are my friends.","ro":"Ei sunt prietenii mei.","words":["w0007","w0012"]},{"id":"s015","en":"I am hungry.","ro":"Mi-e foame.","words":["w0001","w0010","w0023"]},{"id":"s016","en":"It is cold today.","ro":"E frig azi.","words":["w0005","w0011","w0024","w0062"]},{"id":"s017","en":"The car is new.","ro":"Mașina e nouă.","words":["w0011","w0040","w0041"]},{"id":"s018","en":"The shop is open.","ro":"Magazinul e deschis.","words":["w0011","w0054","w0057"]},{"id":"s019","en":"You are right.","ro":"Ai dreptate.","words":["w0002","w0012"]},{"id":"s020","en":"I am at the supermarket.","ro":"Sunt la supermarket.","words":["w0001","w0010"]},{"id":"s021","en":"She is at home.","ro":"Ea e acasă.","words":["w0004","w0011","w0025"]},{"id":"s022","en":"The keys are on the table.","ro":"Cheile sunt pe masă.","words":["w0012"]},{"id":"s023","en":"It is a beautiful day.","ro":"E o zi frumoasă.","words":["w0005","w0011","w0066"]},{"id":"s024","en":"I have a car.","ro":"Am o mașină.","words":["w0001","w0040"]},{"id":"s025","en":"I have two children.","ro":"Am doi copii.","words":["w0001"]},{"id":"s026","en":"I have a problem.","ro":"Am o problemă.","words":["w0001"]},{"id":"s027","en":"I am tired.","ro":"Sunt obosit.","words":["w0001","w0010","w0021"]},{"id":"s028","en":"She is a doctor.","ro":"Ea e doctor.","words":["w0004","w0011","w0086"]},{"id":"s029","en":"I am working.","ro":"Lucrez.","words":["w0001","w0010","w0027"]},{"id":"s030","en":"I am eating breakfast.","ro":"Mănânc micul-dejun.","words":["w0001","w0010","w0028"]},{"id":"s031","en":"She is sleeping.","ro":"Ea doarme.","words":["w0004","w0011","w0029"]},{"id":"s032","en":"He is reading a book.","ro":"El citește o carte.","words":["w0003","w0011","w0030","w0037"]},{"id":"s033","en":"They are playing football.","ro":"Ei joacă fotbal.","words":["w0007","w0012","w0031"]},{"id":"s034","en":"We are watching TV.","ro":"Ne uităm la TV.","words":["w0006","w0012","w0032"]},{"id":"s035","en":"The kids are running.","ro":"Copiii aleargă.","words":["w0012","w0033"]},{"id":"s036","en":"I am learning English.","ro":"Învăț engleză.","words":["w0001","w0010","w0034"]},{"id":"s037","en":"You are speaking too fast.","ro":"Vorbești prea repede.","words":["w0002","w0012"]},{"id":"s038","en":"She is writing a letter.","ro":"Ea scrie o scrisoare.","words":["w0004","w0011","w0035"]},{"id":"s039","en":"It is raining.","ro":"Plouă.","words":["w0005","w0011"]},{"id":"s040","en":"The cat is sleeping on the bed.","ro":"Pisica doarme în pat.","words":["w0011","w0029"]},{"id":"s041","en":"My wife is cooking dinner.","ro":"Soția gătește cina.","words":["w0011","w0017"]},{"id":"s042","en":"I am going home.","ro":"Mă duc acasă.","words":["w0001","w0010","w0025","w0036"]},{"id":"s043","en":"We are waiting for the bus.","ro":"Așteptăm autobuzul.","words":["w0006","w0012"]},{"id":"s044","en":"He is talking on the phone.","ro":"Vorbește la telefon.","words":["w0003","w0011"]},{"id":"s045","en":"The shop is closing now.","ro":"Magazinul se închide acum.","words":["w0011","w0054","w0065"]},{"id":"s046","en":"I am drinking water.","ro":"Beau apă.","words":["w0001","w0010","w0039"]},{"id":"s047","en":"They are coming home tomorrow.","ro":"Vin acasă mâine.","words":["w0007","w0012","w0025","w0063"]},{"id":"s048","en":"I am learning a lot.","ro":"Învăț mult.","words":["w0001","w0010","w0034"]},{"id":"s049","en":"What is your name?","ro":"Cum te cheamă?","words":["w0011","w0020","w0045"]},{"id":"s050","en":"Where are you from?","ro":"De unde ești?","words":["w0002","w0012","w0047"]},{"id":"s051","en":"Where is the station?","ro":"Unde e gara?","words":["w0011","w0047","w0055"]},{"id":"s052","en":"Where is the bus stop?","ro":"Unde e stația de autobuz?","words":["w0011","w0047"]},{"id":"s053","en":"What time is it?","ro":"Cât e ceasul?","words":["w0005","w0011","w0045"]},{"id":"s054","en":"Who is your boss?","ro":"Cine e șeful tău?","words":["w0011","w0046"]},{"id":"s055","en":"When is the meeting?","ro":"Când e ședința?","words":["w0011","w0048"]},{"id":"s056","en":"Why are you here?","ro":"De ce ești aici?","words":["w0002","w0012","w0049"]},{"id":"s057","en":"Are you Romanian?","ro":"Ești român?","words":["w0002","w0012"]},{"id":"s058","en":"Is the shop open?","ro":"Magazinul e deschis?","words":["w0011","w0054","w0057"]},{"id":"s059","en":"Are you working today?","ro":"Lucrezi azi?","words":["w0002","w0012","w0027","w0062"]},{"id":"s060","en":"Is it expensive?","ro":"E scump?","words":["w0005","w0011","w0059"]},{"id":"s061","en":"Are you ready?","ro":"Ești gata?","words":["w0002","w0012"]},{"id":"s062","en":"Is the bus coming?","ro":"Vine autobuzul?","words":["w0011"]},{"id":"s063","en":"Is this seat free?","ro":"E liber locul ăsta?","words":["w0008","w0011"]},{"id":"s064","en":"Am I right?","ro":"Am dreptate?","words":["w0001","w0010"]},{"id":"s065","en":"I'm not tired.","ro":"Nu sunt obosit.","words":["w0021","w0060"]},{"id":"s066","en":"I'm not Romanian, I'm Moldovan.","ro":"Nu sunt român, sunt moldovean.","words":["w0060"]},{"id":"s067","en":"She isn't my wife.","ro":"Ea nu e soția mea.","words":["w0004","w0017"]},{"id":"s068","en":"It isn't cold today.","ro":"Nu e frig azi.","words":["w0005","w0024","w0062"]},{"id":"s069","en":"We aren't ready.","ro":"Nu suntem gata.","words":["w0006"]},{"id":"s070","en":"They aren't at home.","ro":"Nu sunt acasă.","words":["w0007","w0025"]},{"id":"s071","en":"The shop isn't open.","ro":"Magazinul nu e deschis.","words":["w0054","w0057"]},{"id":"s072","en":"I'm not working today.","ro":"Nu lucrez azi.","words":["w0027","w0060","w0062"]},{"id":"s073","en":"She isn't sleeping.","ro":"Nu doarme.","words":["w0004","w0029"]},{"id":"s074","en":"He isn't coming tonight.","ro":"Nu vine în seara asta.","words":["w0003"]},{"id":"s075","en":"It isn't raining any more.","ro":"Nu mai plouă.","words":["w0005"]},{"id":"s076","en":"The bus isn't coming.","ro":"Nu vine autobuzul.","words":[]},{"id":"s077","en":"I'm not feeling well.","ro":"Nu mă simt bine.","words":["w0060"]},{"id":"s078","en":"The room isn't clean.","ro":"Camera nu e curată.","words":[]},{"id":"s079","en":"We aren't waiting.","ro":"Nu așteptăm.","words":["w0006"]},{"id":"s080","en":"Please.","ro":"Te rog.","words":["w0075"]},{"id":"s081","en":"Thank you.","ro":"Mulțumesc.","words":["w0002"]},{"id":"s082","en":"You're welcome.","ro":"Cu plăcere.","words":["w0078"]},{"id":"s083","en":"Excuse me.","ro":"Scuzați-mă.","words":[]},{"id":"s084","en":"I'm sorry, I don't understand.","ro":"Îmi pare rău, nu înțeleg.","words":["w0001","w0077"]},{"id":"s085","en":"Could you speak slower, please?","ro":"Puteți vorbi mai încet, vă rog?","words":["w0002","w0075","w0080"]},{"id":"s086","en":"What does this mean?","ro":"Ce înseamnă asta?","words":["w0008","w0045"]},{"id":"s087","en":"How do you say this in English?","ro":"Cum se spune asta în engleză?","words":["w0002","w0008","w0050"]},{"id":"s088","en":"Excuse me, where is the toilet?","ro":"Scuzați-mă, unde e toaleta?","words":["w0011","w0047"]},{"id":"s089","en":"Could you help me, please?","ro":"Mă puteți ajuta, vă rog?","words":["w0002","w0075","w0080"]},{"id":"s090","en":"Can I have a coffee, please?","ro":"Pot să iau o cafea, vă rog?","words":["w0001","w0075","w0079","w0085"]},{"id":"s091","en":"One ticket to London, please.","ro":"Un bilet la Londra, vă rog.","words":["w0075","w0084"]},{"id":"s092","en":"It hurts here.","ro":"Mă doare aici.","words":["w0005"]},{"id":"s093","en":"I need a doctor.","ro":"Am nevoie de un doctor.","words":["w0001","w0083","w0086"]},{"id":"s094","en":"How are you?","ro":"Ce mai faci?","words":["w0002","w0012","w0050"]},{"id":"s095","en":"I'm fine, thanks. And you?","ro":"Bine, mersi. Tu?","words":["w0002","w0076"]},{"id":"s096","en":"I am married.","ro":"Sunt căsătorit.","words":["w0001","w0010"]},{"id":"s097","en":"Hi, my name is Marcus.","ro":"Salut, mă numesc Marcus.","words":["w0011","w0020","w0072"]},{"id":"s098","en":"I am 47 years old.","ro":"Am 47 de ani.","words":["w0001","w0010","w0042"]},{"id":"s099","en":"I am from Romania, from a small city near Cluj.","ro":"Sunt din România, dintr-un oraș mic de lângă Cluj.","words":["w0001","w0010"]},{"id":"s100","en":"My wife's name is Elena.","ro":"Soția mea se numește Elena.","words":["w0011","w0020"]},{"id":"s101","en":"She is 45.","ro":"Ea are 45 de ani.","words":["w0004","w0011"]},{"id":"s102","en":"We have two children - a boy and a girl.","ro":"Avem doi copii - un băiat și o fată.","words":["w0006"]},{"id":"s103","en":"They are 19 and 16.","ro":"Ei au 19 și 16 ani.","words":["w0007","w0012"]},{"id":"s104","en":"I am working in the Netherlands now.","ro":"Acum lucrez în Olanda.","words":["w0001","w0010","w0027","w0065"]},{"id":"s105","en":"I am a warehouse worker.","ro":"Sunt muncitor la depozit.","words":["w0001","w0010"]},{"id":"s106","en":"The work is not easy, but the people are nice.","ro":"Munca nu e ușoară, dar oamenii sunt drăguți.","words":["w0011","w0012","w0026","w0044","w0060"]},{"id":"s107","en":"After this contract, we are going back to Romania.","ro":"După acest contract, ne întoarcem în România.","words":["w0006","w0008","w0012","w0036"]},{"id":"s108","en":"The kids miss us, but they understand.","ro":"Copiilor le e dor de noi, dar înțeleg.","words":["w0007"]},{"id":"s109","en":"Today it is cold and raining.","ro":"Azi e frig și plouă.","words":["w0005","w0011","w0024","w0062"]},{"id":"s110","en":"I am tired but I am happy.","ro":"Sunt obosit, dar sunt fericit.","words":["w0001","w0010","w0021","w0022"]},{"id":"s111","en":"My English is not very good.","ro":"Engleza mea nu e foarte bună.","words":["w0011","w0043","w0060"]}],"grammar":[{"id":"g1","title":"Vârsta se spune cu verbul 'a fi', nu 'a avea'","body":"În română spunem \"am 50 de ani\", ca și cum am poseda ceva. În engleză însă, pentru vârstă se folosește verbul a fi (to be) - I am 50 - nu a avea (have). E o capcană clasică, pentru că traducem cuvânt cu cuvânt din română. Ține minte: vârsta, la fel ca foamea sau frigul, se exprimă cu a fi în engleză, niciodată cu have.","examples":[{"en":"I am 50 years old.","ro":"Am 50 de ani."},{"en":"She is 30 years old.","ro":"Ea are 30 de ani."},{"en":"They are 18.","ro":"Au 18 ani."},{"en":"He is 25 years old.","ro":"El are 25 de ani."}]},{"id":"g2","title":"Engleza nu poate sta fără verb","body":"Spre deosebire de română, unde poți răspunde scurt doar cu adjectivul (\"Obosit.\"), engleza cere mereu ca propoziția să aibă un verb. Dacă ai un subiect ca I, you, he, she, it, we, they, trebuie neapărat să pui și verbul am, is sau are după el. La fel, ca să negi o propoziție sau să faci o întrebare, ai nevoie de un verb ajutător - ceva ce limba română nu cere. Asta e cea mai mare diferență de structură dintre engleză și română.","examples":[{"en":"I am tired.","ro":"Sunt obosit."},{"en":"She is a doctor.","ro":"Ea este medic."},{"en":"Is the cat playing?","ro":"Se joacă pisica?"},{"en":"He is not working today.","ro":"El nu lucrează azi."}]},{"id":"g3","title":"Cele trei forme ale verbului 'to be'","body":"Verbul românesc a fi are o singură formă simplă la fiecare persoană: sunt, ești, este, suntem, sunteți, sunt. În engleză, to be are trei forme diferite la prezent: am (pentru eu), is (pentru el, ea sau un lucru) și are (pentru tu, noi, voi, ei sau ele). Trebuie să știi mereu ce formă merge cu ce persoană, pentru că e verbul cel mai folosit din toată limba engleză.","examples":[{"en":"I am Romanian.","ro":"Eu sunt român."},{"en":"You are right.","ro":"Tu ai dreptate."},{"en":"He is my son.","ro":"El e fiul meu."},{"en":"She is my wife.","ro":"Ea e soția mea."},{"en":"We are a family.","ro":"Suntem o familie."},{"en":"They are my friends.","ro":"Ei sunt prietenii mei."}]},{"id":"g4","title":"Când folosești 'to be': patru situații","body":"Verbul to be apare de fiecare dată când vorbești despre cine ești (nume, profesie, naționalitate), câți ani ai, cum te simți sau cum e ceva, și unde te afli. Nu-l confunda cu a avea (have) - vezi capcana de mai jos. Practic, oriunde în română ai zice sunt, este sau suntem pentru identitate, stare sau locație, în engleză pui am, is sau are.","examples":[{"en":"I am a driver.","ro":"Sunt șofer."},{"en":"I am 50.","ro":"Am 50 de ani."},{"en":"I am hungry.","ro":"Mi-e foame."},{"en":"I am at home.","ro":"Sunt acasă."}]},{"id":"g5","title":"Contracțiile - cum vorbesc englezii de fapt","body":"Când vorbesc, englezii aproape niciodată nu spun forma lungă I am sau she is - o scurtează, lipind verbul de pronume: I'm, she's, we're. Astea se numesc contracții și trebuie învățate din prima zi, pentru că așa sună engleza naturală, nu doar cea din manual. În scris formal poți folosi forma lungă, dar în vorbire și mesaje informale, contracția e normalul.","examples":[{"en":"I am -> I'm","ro":"Eu sunt."},{"en":"You are -> You're","ro":"Tu ești."},{"en":"She is -> She's","ro":"Ea este."},{"en":"We are -> We're","ro":"Noi suntem."},{"en":"They are -> They're","ro":"Ei sunt."}]},{"id":"g6","title":"Formula prezentului continuu: am/is/are + verb-ing","body":"Când vrei să spui ce faci exact acum, în acest moment, engleza folosește două verbe împreună: mai întâi am, is sau are, apoi verbul de acțiune cu terminația -ing. În română ai nevoie doar de un verb (\"lucrez\"), dar în engleză trebuie neapărat de amândouă - dacă lipsește unul din ele, propoziția sună greșit sau incompletă.","examples":[{"en":"I am working.","ro":"Lucrez (acum)."},{"en":"She is eating.","ro":"Ea mănâncă."},{"en":"They are playing.","ro":"Ei joacă."},{"en":"The cat is sleeping.","ro":"Pisica doarme."}]},{"id":"g7","title":"Cum formezi verbul cu -ing","body":"Majoritatea verbelor primesc pur și simplu -ing la sfârșit (work devine working). Dacă verbul se termină în -e, scoți e-ul înainte de a adăuga -ing (write devine writing). Dacă verbul e scurt și se termină în consoană-vocală-consoană, dublezi ultima consoană (sit devine sitting, run devine running). Și încă un lucru important la pronunție: nu se aude 'g'-ul de la sfârșit - sună ca un 'n' prelungit prin nas.","examples":[{"en":"work -> working","ro":"lucrând"},{"en":"write -> writing","ro":"scriind"},{"en":"sit -> sitting","ro":"stând jos"},{"en":"run -> running","ro":"alergând"}]},{"id":"g8","title":"Când folosești prezentul continuu","body":"Folosești acest timp în trei situații: pentru ceva ce se întâmplă chiar în clipa asta, pentru ceva ce faci în perioada asta (nu neapărat chiar acum, dar zilele astea ești în proces), și pentru planuri deja stabilite în viitorul apropiat. Reține și excepția: verbele de stare, ca want, like, know, have (posesie), understand, need, nu se folosesc niciodată cu -ing - la ele rămâi la forma simplă.","examples":[{"en":"I am learning English.","ro":"Învăț engleză (în perioada asta)."},{"en":"We are flying to London on Monday.","ro":"Zburăm la Londra luni."},{"en":"I want a coffee.","ro":"Vreau o cafea."}]},{"id":"g9","title":"Inversiunea: cum faci întrebări cu to be","body":"În română faci o întrebare doar schimbând tonul vocii - cuvintele rămân la fel. În engleză nu e de-ajuns: trebuie să muți verbul am, is sau are înaintea subiectului. Asta se numește inversiune. La răspuns, nu poți spune doar adjectivul, ca în română - repeți pronumele și verbul: Yes, I am sau No, I'm not.","examples":[{"en":"You are tired. -> Are you tired?","ro":"Ești obosit?"},{"en":"She is happy. -> Is she happy?","ro":"E fericită?"},{"en":"Are you tired? -> Yes, I am.","ro":"Ești obosit? -> Da, sunt."},{"en":"Is she happy? -> No, she isn't.","ro":"E fericită? -> Nu, nu e."}]},{"id":"g10","title":"Întrebări la prezent continuu - aceeași regulă","body":"Când ai deja am/is/are plus verb-ing, regula de inversiune se aplică la fel: doar verbul am/is/are trece în față, iar verbul cu -ing rămâne pe loc, după subiect.","examples":[{"en":"She is reading. -> Is she reading?","ro":"Citește?"},{"en":"They are playing. -> Are they playing?","ro":"Se joacă?"},{"en":"The cat is sleeping. -> Is the cat sleeping?","ro":"Doarme pisica?"}]},{"id":"g11","title":"Wh-întrebările: what, where, who, when","body":"Ca să pornești o conversație, nu doar să răspunzi da sau nu, folosești cuvinte de întrebare ca what, where, who, when, why, how. Formula e simplă: cuvântul de întrebare vine primul, apoi verbul am/is/are, apoi subiectul, apoi restul propoziției.","examples":[{"en":"What is your name?","ro":"Cum te cheamă?"},{"en":"Where are you from?","ro":"De unde ești?"},{"en":"How old is he?","ro":"Câți ani are?"},{"en":"Who is that?","ro":"Cine e acela?"}]},{"id":"g12","title":"Negația cu to be: 'not' vine după verb","body":"În română pui 'nu' înaintea verbului: nu lucrez. În engleză, not vine după verbul ajutător am, is sau are, nu înainte. Formula e simplă: subiect + am/is/are + not + restul propoziției.","examples":[{"en":"I am not tired.","ro":"Nu sunt obosit."},{"en":"She is not happy.","ro":"Ea nu e fericită."},{"en":"They are not home.","ro":"Nu sunt acasă."}]},{"id":"g13","title":"Contracțiile negative","body":"La fel ca la afirmații, englezii aproape mereu scurtează negația în vorbire: is not devine isn't, are not devine aren't. Excepție ciudată: pentru I nu există amn't - se spune doar I'm not. Ține minte asta ca pe o regulă separată, fără logică, dar obligatorie.","examples":[{"en":"She is not -> She isn't","ro":"Ea nu e."},{"en":"They are not -> They aren't","ro":"Nu sunt."},{"en":"I am not -> I'm not","ro":"Nu sunt."}]},{"id":"g14","title":"Negația la prezent continuu","body":"Regula e identică: not merge după am/is/are, înaintea verbului cu -ing.","examples":[{"en":"She isn't working today.","ro":"Nu lucrează azi."},{"en":"They aren't playing.","ro":"Nu se joacă."},{"en":"It isn't raining.","ro":"Nu plouă."}]},{"id":"g15","title":"Salutul potrivit pentru fiecare moment al zilei","body":"Engleza are saluturi diferite în funcție de ora din zi: dimineața good morning, după-amiaza good afternoon, seara good evening. Atenție: good night nu e un salut de întâlnire, ci se folosește doar când pleci seara sau te culci. Pentru orice moment, mai neutru și mai simplu, poți spune oricând hello sau, informal, hi.","examples":[{"en":"Good morning.","ro":"Bună dimineața."},{"en":"Good afternoon.","ro":"Bună ziua."},{"en":"Good evening.","ro":"Bună seara."},{"en":"Good night.","ro":"Noapte bună."}]},{"id":"g16","title":"'How are you?' e mai mult un salut decât o întrebare","body":"Când cineva te întreabă How are you?, engleza nu se așteaptă la un răspuns lung și sincer despre problemele tale - e mai degrabă parte din salut. Răspunzi scurt și pozitiv, chiar dacă nu ești chiar bine: I'm fine, thanks sau I'm good, thanks, și apoi întrebi și tu înapoi And you?.","examples":[{"en":"How are you?","ro":"Ce mai faci?"},{"en":"I'm fine, thanks. And you?","ro":"Bine, mersi. Tu?"},{"en":"Not bad, thanks.","ro":"Nu rău, mersi."}]},{"id":"g17","title":"Politețea e obligatorie: 'please' și 'thank you'","body":"Englezii folosesc please și thank you sau sorry mult mai des decât românii, aproape la fiecare cerere sau mic incident. O cerere fără please sună abrupt și nepoliticos, chiar dacă gramatical e corectă. La fel, excuse me (pentru a cere atenția cuiva) și sorry (pentru a-ți cere scuze) nu sunt interschimbabile.","examples":[{"en":"Can I have a coffee, please?","ro":"Pot să iau o cafea, vă rog?"},{"en":"Thank you very much.","ro":"Mulțumesc mult."},{"en":"Excuse me, where is the toilet?","ro":"Scuzați-mă, unde e toaleta?"},{"en":"Sorry!","ro":"Scuze!"}]}],"traps":[{"wrong":"I have 50 years.","right":"I am 50 years old.","why":"Vârsta se exprimă cu verbul 'a fi', nu cu 'a avea', în engleză."},{"wrong":"Is the cat play?","right":"Is the cat playing?","why":"Verbul principal trebuie să rămână la forma -ing chiar și în întrebare."},{"wrong":"Yes, I tired.","right":"Yes, I am. / Yes, I am tired.","why":"Engleza nu permite propoziții fără verb, spre deosebire de română."},{"wrong":"I am working at supermarket.","right":"I am working at a supermarket.","why":"Substantivele numărabile la singular cer un articol (a/an/the) în engleză."},{"wrong":"He no work today.","right":"He is not working today. / He doesn't work today.","why":"Negația cere un verb ajutător (is not / doesn't), nu doar 'no' plus verb."},{"wrong":"I have hunger.","right":"I am hungry.","why":"Foamea, setea, frigul se exprimă cu 'a fi' plus adjectiv, nu cu 'a avea' plus substantiv."},{"wrong":"I tired.","right":"I am tired.","why":"Nu poți sări peste verbul am/is/are, chiar dacă subiectul e clar din context."},{"wrong":"She doctor.","right":"She is a doctor.","why":"Lipsesc verbul 'is' și articolul 'a' înaintea profesiei."},{"wrong":"We Romanian.","right":"We are Romanian.","why":"Fără verbul 'are', propoziția engleză sună incompletă și greșită."},{"wrong":"I working at the supermarket.","right":"I am working at the supermarket.","why":"Forma cu -ing nu poate sta singură, are nevoie de am/is/are înainte."},{"wrong":"I am work at the supermarket.","right":"I am working at the supermarket.","why":"Dacă pui am/is/are, verbul următor trebuie să primească -ing."},{"wrong":"I am wanting a coffee.","right":"I want a coffee.","why":"Verbele de stare (want, like, know, have, understand, need) nu primesc -ing, ele descriu stări, nu acțiuni."},{"wrong":"What you name is?","right":"What is your name?","why":"La întrebări cu wh-cuvânt, ordinea e wh-cuvânt + verb ajutător + subiect, nu ca în română."},{"wrong":"You are coming?","right":"Are you coming?","why":"În engleză trebuie mutat verbul la început, nu doar schimbat tonul vocii ca în română."},{"wrong":"John is tired?","right":"Is John tired?","why":"Verbul am/is/are trebuie să vină înaintea subiectului la întrebare, nu după."},{"wrong":"I no tired.","right":"I'm not tired.","why":"'No' se folosește doar ca răspuns singur; pentru a nega o propoziție ai nevoie de 'not'."},{"wrong":"I don't have nothing.","right":"I don't have anything.","why":"Engleza acceptă un singur cuvânt de negație pe propoziție, spre deosebire de română."},{"wrong":"Sorry, where is the station?","right":"Excuse me, where is the station?","why":"'Sorry' e pentru regret, 'excuse me' e pentru a cere atenția cuiva."},{"wrong":"I want a coffee.","right":"Can I have a coffee, please?","why":"În engleză, cererea directă fără 'please' sună nepoliticos și abrupt."}],"lessons":[{"id":"u01l1","title":"Cele 5 greșeli tipice","vocab":[],"sentences":["s001","s002","s003","s004","s005","s006","s007","s008"],"grammar":"g1"},{"id":"u01l2","title":"Verbul to be - am I","vocab":["w0001","w0002","w0003","w0004","w0005","w0006"],"sentences":["s009","s010","s011","s012","s013","s015","s016","s019"],"grammar":"g3"},{"id":"u01l3","title":"Verbul to be - am II","vocab":["w0007","w0008","w0009","w0010","w0011","w0012"],"sentences":["s014","s009","s010","s011","s012","s013","s015","s016"],"grammar":null},{"id":"u01l4","title":"Verbul to be - am III","vocab":["w0013","w0014","w0015","w0016","w0017","w0018"],"sentences":["s011","s013","s009","s010","s012","s014","s015","s016"],"grammar":null},{"id":"u01l5","title":"Verbul to be - am IV","vocab":["w0019","w0020","w0021","w0022","w0023","w0024"],"sentences":["s015","s016","s027","s009","s010","s011","s012","s013"],"grammar":null},{"id":"u01l6","title":"Verbul to be - am V","vocab":["w0025","w0026"],"sentences":["s021","s009","s010","s011","s012","s013","s014","s015"],"grammar":null},{"id":"u01l7","title":"Prezent continuu - ce I","vocab":["w0027","w0028","w0029","w0030","w0031","w0032"],"sentences":["s029","s030","s031","s032","s033","s034","s040","s035"],"grammar":"g6"},{"id":"u01l8","title":"Prezent continuu - ce II","vocab":["w0033","w0034","w0035","w0036","w0037","w0038"],"sentences":["s032","s035","s036","s038","s042","s048","s029","s030"],"grammar":null},{"id":"u01l9","title":"Prezent continuu - ce III","vocab":["w0039","w0040","w0041","w0042","w0043","w0044"],"sentences":["s046","s029","s030","s031","s032","s033","s034","s035"],"grammar":null},{"id":"u01l10","title":"Întrebări cu is, are I","vocab":["w0045","w0046","w0047","w0048","w0049","w0050"],"sentences":["s049","s050","s051","s052","s053","s054","s055","s056"],"grammar":"g9"},{"id":"u01l11","title":"Întrebări cu is, are II","vocab":["w0051","w0052","w0053","w0054","w0055","w0056"],"sentences":["s051","s058","s049","s050","s052","s053","s054","s055"],"grammar":null},{"id":"u01l12","title":"Întrebări cu is, are III","vocab":["w0057","w0058","w0059"],"sentences":["s058","s060","s049","s050","s051","s052","s053","s054"],"grammar":null},{"id":"u01l13","title":"Negații - nu sunt, nu I","vocab":["w0060","w0061","w0062","w0063","w0064","w0065"],"sentences":["s072","s065","s066","s068","s077","s067","s069","s070"],"grammar":"g12"},{"id":"u01l14","title":"Negații - nu sunt, nu II","vocab":["w0066","w0067","w0068","w0069","w0070"],"sentences":["s065","s066","s067","s068","s069","s070","s071","s072"],"grammar":null},{"id":"u01l15","title":"Saluturi și fraze de I","vocab":["w0071","w0072","w0073","w0074","w0075","w0076"],"sentences":["s080","s085","s089","s090","s091","s095","s081","s082"],"grammar":"g15"},{"id":"u01l16","title":"Saluturi și fraze de II","vocab":["w0077","w0078","w0079","w0080","w0081","w0082"],"sentences":["s082","s084","s085","s089","s090","s080","s081","s083"],"grammar":null},{"id":"u01l17","title":"Saluturi și fraze de III","vocab":["w0083","w0084","w0085","w0086"],"sentences":["s093","s090","s091","s080","s081","s082","s083","s084"],"grammar":null},{"id":"u01l18","title":"Recapitulare","vocab":[],"sentences":["s097","s098","s099","s100","s101","s102","s103","s104"],"grammar":null}]}